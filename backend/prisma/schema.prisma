generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id              Int     @id @default(autoincrement())
  cnpj            String? @unique
  razao_social    String?
  modules_allowed String?
  users                User[]
  suppliers            Supplier[]
  tickets              Ticket[]
  financial_transactions FinancialTransaction[]
  products             Product[]
  manual_orders        ManualOrder[]
  quotations           Quotation[]

  @@map("companies")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  role       String
  company_id Int?
  company    Company? @relation(fields: [company_id], references: [id])

  @@map("users")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  nome      String
  contato   String?
  telefone  String?
  email     String?
  categoria String?
  status    String   @default("Ativo")
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  @@map("suppliers")
}

model Ticket {
  id        Int      @id @default(autoincrement())
  titulo    String
  categoria String
  status    String   @default("aberto")
  autor     String?
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tickets")
}

model FinancialTransaction {
  id          Int      @id @default(autoincrement())
  descricao   String
  valor       Float
  tipo        String   // 'PAGAR' ou 'RECEBER'
  vencimento  DateTime
  status      String   @default("Pendente")
  fornecedor  String?
  companyId   Int?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())

  @@map("financial_transactions")
}

model Product {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String?
  valor       String
  categoria   String?
  companyId   Int?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())

  @@map("products")
}

model ManualOrder {
  id          Int      @id @default(autoincrement())
  cpf         String?
  itens       String
  status      String   @default("Novo")
  total       String?
  companyId   Int?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("manual_orders")
}

model Quotation {
  id            Int      @id @default(autoincrement())
  titulo        String
  fornecedores  String?  // JSON string array of supplier names
  itens         String   // JSON string of items
  status        String   @default("Rascunho")
  melhorPreco   String?
  companyId     Int?
  company       Company? @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("quotations")
}
